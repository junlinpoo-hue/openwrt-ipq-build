#设备平台
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq807x=y
#设备列表
CONFIG_TARGET_qualcommax_ipq807x_DEVICE_aliyun_ap8220=y

#WIFI驱动
CONFIG_PACKAGE_kmod-ath=n
CONFIG_PACKAGE_kmod-ath11k=n
CONFIG_PACKAGE_kmod-ath11k-ahb=n
CONFIG_PACKAGE_kmod-ath11k-pci=n
CONFIG_PACKAGE_ath10k-firmware-qca9887=n
CONFIG_PACKAGE_ath11k-firmware-ipq8074=n
CONFIG_PACKAGE_ath11k-firmware-ipq8074-ddwrt=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074-ddwrt=n
# === hostapd/wpad（全部禁用，标准语法）===
CONFIG_PACKAGE_hostapd-common=n
CONFIG_PACKAGE_wpad-openssl=n
CONFIG_PACKAGE_wpad-basic-mbedtls=n
CONFIG_PACKAGE_wpad-basic=n
CONFIG_PACKAGE_wpad-mini=n
CONFIG_PACKAGE_wpad-mbedtls=n
CONFIG_PACKAGE_hostapd-openssl=n
CONFIG_PACKAGE_hostapd-basic-mbedtls=n
CONFIG_PACKAGE_hostapd-mini=n
CONFIG_PACKAGE_hostapd-utils=n
CONFIG_PACKAGE_wpad=n
CONFIG_PACKAGE_hostapd=n

# === 无线相关工具（标准语法）===
CONFIG_PACKAGE_iw=n
CONFIG_PACKAGE_iwinfo=n
CONFIG_PACKAGE_wireless-tools=n
CONFIG_PACKAGE_wifischedule=n
CONFIG_PACKAGE_kmod-mac80211=n
CONFIG_PACKAGE_kmod-cfg80211=n
CONFIG_ATH11K_DEBUGFS_HTT_STATS=n   # 禁用 HTT 统计（调试用）
CONFIG_ATH11K_DEBUGFS_STA=n         # 禁用 STA 调试
CONFIG_ATH11K_THERMAL=n             # 禁用热节流（thermal throttling）

#科学插件调整
CONFIG_PACKAGE_luci-app-homeproxy=n
#增加插件
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-upnp=n
CONFIG_PACKAGE_luci-app-wolplus=n
CONFIG_PACKAGE_smartdns=y
CONFIG_PACKAGE_smartdns-ui=y
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_bind-dig=y
CONFIG_PACKAGE_bind-nslookup=y
#删除插件
CONFIG_PACKAGE_luci-app-attendedsysupgrade=n
CONFIG_PACKAGE_luci-app-wol=n
#参数调整
CONFIG_CCACHE=y                    # ccache 缓存，加速重复编译
CONFIG_DEVEL=y                     # 开发者模式
CONFIG_EXPERIMENTAL=y              # 实验性功能
CONFIG_TOOLCHAINOPTS=y             # 工具链选项
CONFIG_TARGET_OPTIONS=y            # 目标选项
CONFIG_TARGET_MULTI_PROFILE=n
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_TARGET_ROOTFS_INITRAMFS=n
#内核调整
CONFIG_PACKAGE_kmod-bonding=n
CONFIG_PACKAGE_kmod-dsa=y
CONFIG_PACKAGE_kmod-dummy=n
CONFIG_PACKAGE_kmod-fs-btrfs=n
CONFIG_PACKAGE_kmod-fuse=n
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-inet-mptcp-diag=y
CONFIG_PACKAGE_kmod-mtd-rw=n
CONFIG_PACKAGE_kmod-netlink-diag=y
CONFIG_PACKAGE_kmod-nft-arp=y
CONFIG_PACKAGE_kmod-nft-bridge=y
CONFIG_PACKAGE_kmod-nft-connlimit=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-dup-inet=y
CONFIG_PACKAGE_kmod-nft-fib=y
CONFIG_PACKAGE_kmod-nft-fullcone=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-netdev=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nft-queue=y
CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_kmod-nft-tproxy=n
CONFIG_PACKAGE_kmod-nft-xfrm=y
CONFIG_PACKAGE_kmod-sound-core=n
CONFIG_PACKAGE_kmod-tun=n
CONFIG_PACKAGE_kmod-usb3=n
CONFIG_PACKAGE_kmod-usb-audio=n
CONFIG_PACKAGE_kmod-usb-core=n
CONFIG_PACKAGE_kmod-usb-dwc3=n
CONFIG_PACKAGE_kmod-usb-net=n
CONFIG_PACKAGE_kmod-usb-net-asix=n
CONFIG_PACKAGE_kmod-usb-net-asix-ax88179=n
CONFIG_PACKAGE_kmod-usb-net-cdc-eem=n
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=n
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=n
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=n
CONFIG_PACKAGE_kmod-usb-net-cdc-subset=n
CONFIG_PACKAGE_kmod-usb-net-huawei-cdc-ncm=n
CONFIG_PACKAGE_kmod-usb-net-ipheth=n
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=n
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan-fibocom=n
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan-quectel=n
CONFIG_PACKAGE_kmod-usb-net-rndis=n
CONFIG_PACKAGE_kmod-usb-net-rtl8150=n
CONFIG_PACKAGE_kmod-usb-net-rtl8152=n
CONFIG_PACKAGE_kmod-usb-net-sierrawireless=n
CONFIG_PACKAGE_kmod-usb-ohci=n
CONFIG_PACKAGE_kmod-usb-storage=n
CONFIG_PACKAGE_kmod-usb-storage-extras=n
CONFIG_PACKAGE_kmod-usb-storage-uas=n
CONFIG_PACKAGE_kmod-usb-uhci=n
CONFIG_PACKAGE_kmod-usb-xhci=n
CONFIG_PACKAGE_kmod-veth=n
CONFIG_PACKAGE_kmod-wireguard=n
CONFIG_COLLECT_KERNEL_DEBUG=y
CONFIG_KERNEL_PERF_EVENTS=y        # perf 性能分析
CONFIG_KERNEL_DYNAMIC_DEBUG=y      # 动态调试
CONFIG_KERNEL_ARM_PMU=y            # ARM 性能监控单元
CONFIG_KERNEL_PREEMPT_NONE=y       # 无抢占（服务器模式，延迟更低）
CONFIG_KERNEL_PREEMPT_NONE_BUILD=y
#组件调整
CONFIG_PACKAGE_autocore=y
CONFIG_PACKAGE_automount=n
CONFIG_PACKAGE_blkid=n
CONFIG_PACKAGE_cfdisk=n
CONFIG_PACKAGE_cgdisk=n
CONFIG_PACKAGE_coremark=n
CONFIG_PACKAGE_cpufreq=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_dmesg=y
CONFIG_PACKAGE_fdisk=n
CONFIG_PACKAGE_gdisk=n
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_libimobiledevice=n
CONFIG_PACKAGE_lsblk=n
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-base=y
CONFIG_PACKAGE_luci-lib-ipkg=n
CONFIG_PACKAGE_luci-lua-runtime=y
CONFIG_PACKAGE_luci-proto-relay=n
CONFIG_PACKAGE_mmc-utils=n
CONFIG_PACKAGE_nand-utils=n
CONFIG_PACKAGE_openssh-keygen=n
CONFIG_PACKAGE_openssh-sftp-server=n
CONFIG_PACKAGE_openssl-util=n
CONFIG_PACKAGE_proto-bonding=n
CONFIG_PACKAGE_sfdisk=n
CONFIG_PACKAGE_sgdisk=n
CONFIG_PACKAGE_usb-modeswitch=n
CONFIG_PACKAGE_usbmuxd=n
CONFIG_PACKAGE_usbutils=n
CONFIG_PACKAGE_xz-utils=n
#NSS加速显示配置
#WiFi Mesh 加速
#CONFIG_ATH11K_NSS_MESH_SUPPORT=y
#组播嗅探加速
CONFIG_PACKAGE_kmod-qca-mcs=y
#SQM 流量整形加速
CONFIG_PACKAGE_sqm-scripts-nss=y
#编译优化
CONFIG_TARGET_OPTIMIZATION="-O2 -pipe -mcpu=cortex-a53+crc+crypto"
#WiFi 驱动优化
#CONFIG_ATH11K_DEBUGFS_HTT_STATS=n
#CONFIG_ATH11K_DEBUGFS_STA=n
#CONFIG_ATH11K_THERMAL=n
#Feeds 相关
CONFIG_FEED_nss_packages=n
CONFIG_FEED_sqm_scripts_nss=n

CONFIG_ZLIB_OPTIMIZE_SPEED=y       # zlib 压缩库速度优先

CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y
CONFIG_PACKAGE_rpcd=y
CONFIG_PACKAGE_rpcd-mod-luci=y
CONFIG_PACKAGE_luci=y

CONFIG_ZSTD_OPTIMIZE_O3=y          # zstd 压缩库 O3 优化
